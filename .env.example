APP_NAME="nthdesigns Scanner"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use https://your-site.test when serving via Valet/Herd so Vite dev assets match (see vite.config.js).
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nth_scanner
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database — local dev; Laravel Cloud queues (see docs/deployment/laravel-cloud.md)
QUEUE_CONNECTION=database
SEARCH_QUEUE_CONNECTION=database
NICHE_QUEUE_CONNECTION=database
# Deprecated alias for NICHE_QUEUE_CONNECTION on existing deployments
SCRAPING_QUEUE_CONNECTION=database
# Laravel Cloud managed queue: set to cloud (not sqs). Local/dev: database
AUDITING_QUEUE_CONNECTION=database
# Must exceed AuditSiteJob timeout (210s) when using database queue
DB_QUEUE_RETRY_AFTER=200

CACHE_STORE=database

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Object storage for report screenshots (use s3 for Hetzner in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true
REPORTS_DISK=public

VITE_APP_NAME="${APP_NAME}"

# Server-side key: use "IP addresses" or "None" for app restrictions — not HTTP referrers.
# Enable "Places API (New)" on the Google Cloud project.
GOOGLE_PLACES_API_KEY=
OPENROUTER_API_KEY=
# Anthropic models via OpenRouter (see https://openrouter.ai/anthropic)
OPENROUTER_MODEL=anthropic/claude-sonnet-4

HORIZON_PREFIX=nth-scanner
# Comma-separated emails allowed to view /horizon in non-local environments
HORIZON_ALLOWED_EMAILS=

# Audit: playwright (local Node) | http (Fly.io browser service when AUDIT_SERVICE_URL is set) | cloudflare (skip audits; CF screenshots only)
AUDIT_DRIVER=playwright
SCREENSHOT_DRIVER=
AUDIT_SERVICE_URL=
AUDIT_SERVICE_TOKEN=

# Optional: Cloudflare screenshots only (not needed when using Fly for both)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

NODE_BINARY=node
AUDIT_SCRIPT_PATH=
LIGHTHOUSE_BINARY=lighthouse
# Optional: PageSpeed Insights fallback when local Lighthouse fails (set on Fly via fly secrets)
PAGESPEED_API_KEY=
# Laravel Cloud: install Chromium to storage/app/playwright-browsers in build (see docs/deployment/laravel-cloud.md)
# PLAYWRIGHT_BROWSERS_PATH=0
AUDIT_TIMEOUT=210
SCREENSHOT_TIMEOUT=150

REPORT_BOOKING_URL=https://tidycal.com/yourhandle
REPORT_EXPIRY_DAYS=30
SEARCH_RATE_LIMIT_SECONDS=30

# Production scheduler: add cron -> php artisan schedule:run
# Daily purge of expired prospect payloads and reports via scanner:purge-expired
